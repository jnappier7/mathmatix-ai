{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-useless-escape": "warn",
    "no-case-declarations": "warn",
    "no-inner-declarations": "warn",
    "no-prototype-builtins": "warn",
    "no-misleading-character-class": "warn",
    "no-control-regex": "warn"
  },
  "overrides": [
    {
      "files": ["public/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      },
      "parserOptions": {
        "sourceType": "module"
      },
      "rules": {
        "no-undef": "warn",
        "no-func-assign": "warn",
        "no-redeclare": "warn",
        "no-cond-assign": "warn",
        "no-constant-condition": "warn",
        "no-dupe-class-members": "warn"
      }
    },
    {
      "files": ["tests/load/**/*.js"],
      "parserOptions": {
        "sourceType": "module"
      },
      "globals": {
        "__ENV": "readonly"
      }
    },
    {
      "files": ["tests/**/*.js", "test/**/*.js"],
      "env": {
        "jest": true
      },
      "globals": {
        "DOMPurify": "readonly"
      }
    },
    {
      "files": ["vite.config.js"],
      "parserOptions": {
        "sourceType": "module"
      }
    },
    {
      "files": ["scripts/**/*.js"],
      "rules": {
        "no-unused-vars": "off",
        "no-undef": "warn",
        "no-dupe-keys": "warn",
        "no-redeclare": "warn",
        "no-func-assign": "warn",
        "no-constant-condition": "warn"
      }
    },
    {
      "files": ["routes/graph.js"],
      "globals": {
        "window": "readonly",
        "document": "readonly",
        "Desmos": "readonly"
      }
    },
    {
      "files": ["utils/tutorConfig.js"],
      "globals": {
        "window": "readonly"
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    "public/vendor/",
    "public/pdfjs-viewer/",
    "*.min.js"
  ]
}
